# ══════════════════════════════════════════════════════
# WEATHER TRADER BOT — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# NEVER commit .env to git!
# ══════════════════════════════════════════════════════

# Polygon wallet private key (export from Polymarket → Cash → ⋯ → Export Private Key)
POLYGON_PRIVATE_KEY=

# Proxy wallet/funder address (required for Magic/Safe style Polymarket accounts)
PROXY_WALLET=

# Optional override for Polymarket signature type:
# 0 = EOA (no proxy), 1 = POLY_PROXY, 2 = POLY_GNOSIS_SAFE
POLY_SIGNATURE_TYPE=

# Optional retry order for signature-type fallback, comma-separated (example: 2,1)
POLY_SIGNATURE_TYPE_FALLBACKS=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (from @userinfobot or getUpdates API)
TELEGRAM_CHAT_ID=

# Google Apps Script webhook URL (for logging to Google Sheets)
GOOGLE_SHEET_WEBHOOK=

# Tomorrow.io API key (forward-test mode)
TOMORROW_API_KEY=

# Strategy engine: v5 | forward_test_tomorrow
STRATEGY_ENGINE=forward_test_tomorrow

# City scope (comma-separated). Default runtime is NYC-only.
# ENABLED_CITIES=nyc

# Forward-test paper bankroll shown/used in simulation mode
# FORWARD_TEST_PAPER_BANKROLL=500

# Forward-test cadence and model quality settings
# CYCLE_INTERVAL_SECONDS=3600
# FORWARD_RESOLUTION_LOOKBACK_DAYS=4
# FORWARD_ERROR_WINDOW=240
# FORWARD_ERROR_MIN_SAMPLES=20
# FORWARD_ERROR_MAX_SAMPLES_FOR_CONVOLUTION=120
# FORWARD_DAILY_REPORT_UTC_HOUR=7
# FORWARD_DAILY_REPORT_UTC_MINUTE=10

# NYC ingestion capture (Step 2, capture-only)
# NYC_INGESTION_ENABLED=true
# NYC_INGESTION_FORECAST_API=https://previous-runs-api.open-meteo.com/v1/forecast
# NYC_INGESTION_ENSEMBLE_API=https://ensemble-api.open-meteo.com/v1/ensemble
# NYC_INGESTION_FORECAST_DAYS=3
# NYC_INGESTION_TIMEOUT_SECONDS=20
# NYC_INGESTION_ACTIVE_SOURCES=nbm,gefs,ecmwf_ens
# NYC_MODEL_NBM=ncep_nbm_conus
# NYC_MODEL_GEFS=ncep_gefs025
# NYC_MODEL_ECMWF_ENS=ecmwf_ifs025_ensemble
# NYC_WEIGHT_NBM=0.3334
# NYC_WEIGHT_GEFS=0.3333
# NYC_WEIGHT_ECMWF_ENS=0.3333
# NYC_PROB_ENGINE_ENABLED=true
# NYC_PROB_USE_IN_FORWARD=true
# NYC_FORWARD_POLICY_ENABLED=true
# NYC_FORWARD_MIN_MODEL_PROB=0.20
# NYC_FORWARD_MIN_EDGE=0.02
# NYC_FORWARD_MAX_SPREAD=0.08
# NYC_FORWARD_SPREAD_PENALTY_MULT=0.35
# NYC_FORWARD_SWITCH_EDGE_BUFFER=0.01
# NYC_FORWARD_SWITCH_COOLDOWN_MINUTES=60
